# Root gitignore for BlackHorsePub

# Dependencies
**/node_modules/
**/jspm_packages/
**/web_modules/

# Next.js build and cache
**/BlackHorse-frontend/.next/
**/BlackHorse-frontend/out/

# Backend build and target
**/BlackHorse-backend/target/
**/BlackHorse-backend/.mvn/wrapper/maven-wrapper.jar

# Environment files (sensitive data)
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
**/.env.*.local

# Logs
**/*.log
**/frontend-dev.err.log
**/frontend-dev.log
**/backend-dev.err.log
**/backend-dev.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS Files
.DS_Store
Thumbs.db

# IDEs and Editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Temporary / Archives
BlackHorse-backend.zip
